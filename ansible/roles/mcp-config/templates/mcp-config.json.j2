{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    }{% if sentry_auth_token is defined and sentry_auth_token | length > 0 %},
    "sentry": {
      "command": "npx",
      "args": ["-y", "@sentry/mcp-server"],
      "env": {
        "SENTRY_AUTH_TOKEN": "{{ sentry_auth_token }}",
        "SENTRY_ORG_SLUG": "{{ sentry_org_slug | default('') }}"
      }
    }{% endif %}{% if github_personal_access_token is defined and github_personal_access_token | length > 0 %},
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{{ github_personal_access_token }}"
      }
    }{% endif %}
  }
}
