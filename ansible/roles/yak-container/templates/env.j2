APP_NAME=Yak
APP_ENV=production
APP_KEY=base64:{{ yak_app_key }}
APP_DEBUG=false
APP_URL=https://{{ yak_domain }}

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mariadb
DB_HOST=yak-mariadb
DB_PORT=3306
DB_DATABASE=yak
DB_USERNAME=yak
DB_PASSWORD={{ mariadb_password }}

QUEUE_CONNECTION=database

ARTIFACTS_PATH=/data/artifacts

ANTHROPIC_API_KEY={{ anthropic_api_key }}

YAK_MCP_CONFIG_PATH=/home/yak/mcp-config.json
{% if agent_extra_env is defined %}
YAK_AGENT_PASSTHROUGH_ENV={{ agent_extra_env.keys() | join(',') }}
{% endif %}

# GitHub App
YAK_GITHUB_APP_ID={{ github_app_id | default('') }}
YAK_GITHUB_PRIVATE_KEY_PATH=/etc/yak/github-app.pem
YAK_GITHUB_INSTALLATION_ID={{ github_installation_id | default('') }}
YAK_GITHUB_WEBHOOK_SECRET={{ github_webhook_secret | default('') }}

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID={{ google_oauth_client_id }}
GOOGLE_OAUTH_CLIENT_SECRET={{ google_oauth_client_secret }}
GOOGLE_OAUTH_ALLOWED_DOMAINS={{ google_oauth_allowed_domains }}

# Slack
YAK_SLACK_BOT_TOKEN={{ slack_bot_token | default('') }}
YAK_SLACK_SIGNING_SECRET={{ slack_signing_secret | default('') }}

# Linear — OAuth app for outbound comments/state updates (posts as "Yak")
YAK_LINEAR_OAUTH_CLIENT_ID={{ linear_oauth_client_id | default('') }}
YAK_LINEAR_OAUTH_CLIENT_SECRET={{ linear_oauth_client_secret | default('') }}
YAK_LINEAR_OAUTH_REDIRECT_URI={{ linear_oauth_redirect_uri | default('https://' + yak_domain + '/auth/linear/callback') }}
YAK_LINEAR_OAUTH_SCOPES={{ linear_oauth_scopes | default('read,write,app:assignable,app:mentionable') }}
YAK_LINEAR_WEBHOOK_SECRET={{ linear_webhook_secret | default('') }}
YAK_LINEAR_DONE_STATE_ID={{ linear_done_state_id | default('') }}
YAK_LINEAR_CANCELLED_STATE_ID={{ linear_cancelled_state_id | default('') }}
YAK_LINEAR_IN_REVIEW_STATE_ID={{ linear_in_review_state_id | default('') }}

# Sentry
YAK_SENTRY_AUTH_TOKEN={{ sentry_auth_token | default('') }}
YAK_SENTRY_WEBHOOK_SECRET={{ sentry_webhook_secret | default('') }}
YAK_SENTRY_ORG_SLUG={{ sentry_org_slug | default('') }}

# Drone
YAK_DRONE_URL={{ drone_url | default('') }}
YAK_DRONE_TOKEN={{ drone_token | default('') }}
{% if agent_extra_env is defined %}

# Extra environment variables for the agent process
{% for key, value in agent_extra_env.items() %}
{{ key }}={{ value }}
{% endfor %}
{% endif %}
